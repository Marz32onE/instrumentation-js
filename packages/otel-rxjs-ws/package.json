{
  "name": "@marz32one/otel-rxjs-ws",
  "version": "0.2.4",
  "description": "RxJS webSocket-aligned OpenTelemetry trace propagation (embedded + header envelope; compatible with instrumentation-go/otel-gorilla-ws)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./webSocket": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "websocket",
    "rxjs",
    "tracing",
    "instrumentation",
    "w3c-trace-context"
  ],
  "author": "Marz32onE",
  "license": "Apache-2.0",
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@opentelemetry/core": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.7.0",
    "ws": "^8.18.0"
  }
}
