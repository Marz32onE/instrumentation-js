{
  "name": "@marz32one/otel-nats",
  "version": "0.1.0",
  "description": "NATS client OpenTelemetry trace propagation (W3C TraceContext; compatible with instrumentation-go/otel-nats)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./jetstream": {
      "types": "./dist/jetstream.d.ts",
      "import": "./dist/jetstream.js",
      "default": "./dist/jetstream.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest --config jest.integration.config.cjs",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "nats",
    "jetstream",
    "tracing",
    "instrumentation",
    "w3c-trace-context",
    "messaging"
  ],
  "author": "Marz32onE",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "@nats-io/jetstream": "^3.3.0",
    "@nats-io/nats-core": "^3.3.0",
    "@nats-io/transport-node": "^3.3.0",
    "@opentelemetry/api": "^1.9.0"
  },
  "peerDependenciesMeta": {
    "@nats-io/jetstream": {
      "optional": true
    },
    "@nats-io/nats-core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@nats-io/jetstream": "^3.3.1",
    "@nats-io/nats-core": "^3.3.1",
    "@nats-io/transport-node": "^3.3.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/core": "^2.6.0",
    "@opentelemetry/sdk-trace-node": "^2.6.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "jest": "^30.0.0",
    "testcontainers": "^11.14.0",
    "ts-jest": "^29.4.9",
    "typescript": "^6.0.0",
    "ws": "^8.20.0"
  }
}
