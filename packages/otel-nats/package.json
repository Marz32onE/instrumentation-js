{
  "name": "@marz32one/otel-nats",
  "version": "0.1.0",
  "description": "NATS client OpenTelemetry trace propagation (W3C TraceContext; compatible with instrumentation-go/otel-nats)",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./jetstream": {
      "types": "./dist/jetstream.d.ts",
      "import": "./dist/jetstream.js",
      "default": "./dist/jetstream.js"
    }
  },
  "files": [
    "dist/**/*",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "opentelemetry",
    "otel",
    "nats",
    "jetstream",
    "tracing",
    "instrumentation",
    "w3c-trace-context",
    "messaging"
  ],
  "author": "Marz32onE",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0"
  },
  "peerDependencies": {
    "nats": ">=2.26.0"
  },
  "peerDependenciesMeta": {
    "nats": { "optional": false }
  },
  "devDependencies": {
    "@opentelemetry/core": "^1.30.1",
    "@opentelemetry/sdk-trace-node": "^1.30.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.0.0",
    "jest": "^29.7.0",
    "nats": "^2.29.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.7.0"
  }
}
