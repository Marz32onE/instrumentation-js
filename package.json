{
  "name": "instrumentation-js",
  "private": true,
  "workspaces": [
    "packages/otel-ws",
    "packages/otel-rxjs-ws",
    "packages/otel-nats"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint:typecheck": "npm run lint --workspaces",
    "lint:eslint": "eslint packages",
    "lint": "npm run lint:typecheck && npm run lint:eslint",
    "eslint": "eslint packages"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "typescript-eslint": "^8.18.0"
  }
}
