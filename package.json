{
  "name": "instrumentation-js",
  "private": true,
  "workspaces": [
    "packages/otel-ws",
    "packages/otel-rxjs-ws",
    "packages/otel-nats"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "test": "npm run test --workspaces",
    "lint": "npm run lint:types && npm run lint:eslint",
    "lint:types": "npm run lint --workspaces --if-present",
    "lint:eslint": "eslint \"packages/*/src/**/*.ts\" \"packages/*/test/**/*.ts\" --max-warnings 0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "eslint": "^10.0.0",
    "globals": "^17.0.0",
    "typescript-eslint": "^8.58.0"
  }
}
